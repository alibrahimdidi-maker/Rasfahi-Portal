            let lvl = parseInt(document.getElementById('p-level').value) || 5;

            // Optional: calculate row level total/f2f based on row credit if entered manually.
            // MQA generally uses weekly division, but we'll apply standard credit formula per row if credit is provided.
            if(inputElem && inputElem.classList.contains('sch-cr')) {
                let row = inputElem.closest('tr');
                let cr = Number(inputElem.value) || 0;
                let tot = cr * 10;
                let con = (lvl <= 3) ? (tot * 0.5) : (tot / 3);
                row.querySelector('.sch-th').value = tot;
                row.querySelector('.sch-f2f').value = Math.round(con);
