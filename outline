                    <tr><td style="border:1px solid black; padding:8px;">Highest Qualification:</td><td style="border:1px solid black; padding:8px; text-align:right;">${document.getElementById('d-qual').value}</td></tr>
                    <tr><td style="border:1px solid black; padding:8px;">Designation and Office:</td><td style="border:1px solid black; padding:8px; text-align:right;">${document.getElementById('d-desig').value}</td></tr>
                    <tr><td style="border:1px solid black; padding:8px;">E-mail and Contact:</td><td style="border:1px solid black; padding:8px; text-align:right;">${document.getElementById('d-mail').value}</td></tr>
                </table>
            </div>`;
            return html;
        }

        function buildFullProgramHTML() {
            let modHTML = buildModuleHTML();
            let html = `
            <div style="font-family: 'Faruma', 'Amiri', serif; direction: rtl; font-size: 13pt; line-height: 1.6; color:black; background: white; padding: 20px;">
                <div style="text-align:center; margin-bottom: 50px;">
                    <h1 style="font-size: 26pt; margin-bottom: 10px;">${document.getElementById('p-inst').value}</h1>
                    <h2 style="font-size: 20pt; margin-bottom: 30px;">ޕްރޮގްރާމް އައުޓްލައިން</h2>
                    <h3 style="font-size: 18pt;">${document.getElementById('p-name').value}</h3>
                    <p style="direction:ltr; font-family:'Segoe UI', sans-serif; font-size:14pt; margin-top:10px; font-weight:bold;">MNQF Level: ${document.getElementById('p-level').value} | Duration: ${document.getElementById('p-dur').value}</p>
                </div>
                <div style="page-break-before: always;"></div>
                <h1 style="direction:ltr; font-family:'Segoe UI', sans-serif; text-align:center; margin-bottom:20px; border-bottom:3px solid black; padding-bottom:10px;">PART A</h1>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">1. Institutional Capacity and Management</h3>
                <p style="text-align:justify; margin-bottom:15px;">${document.getElementById('p-intro').value.replace(/\n/g, '<br>')}</p>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">2. Facilities</h3>
                <p style="text-align:justify; margin-bottom:15px;">${document.getElementById('p-fac').value.replace(/\n/g, '<br>')}</p>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">3. Internal Quality Assurance Mechanism</h3>
                <p style="text-align:justify; margin-bottom:15px;">${document.getElementById('p-iqa').value.replace(/\n/g, '<br>')}</p>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">4. Instruction and Academic Staffing</h3>
                <p style="text-align:justify; margin-bottom:15px;">${document.getElementById('a-staff').value.replace(/\n/g, '<br>')}</p>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">5. General Student Assessment Policies</h3>
                <p style="text-align:justify; margin-bottom:15px;">${document.getElementById('a-assess').value.replace(/\n/g, '<br>')}</p>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">6. Student Withdrawal</h3>
                <p style="text-align:justify; margin-bottom:15px;">${document.getElementById('a-withdraw').value.replace(/\n/g, '<br>')}</p>

                <div style="page-break-before: always;"></div>
                <h1 style="direction:ltr; font-family:'Segoe UI', sans-serif; text-align:center; margin-bottom:20px; border-bottom:3px solid black; padding-bottom:10px;">PART B</h1>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">7. Admission & Policies</h3>
                <p style="direction:ltr; font-family:'Segoe UI', sans-serif; text-align:left; margin-bottom:15px;">${document.getElementById('b-admin').value.replace(/\n/g, '<br>')}</p>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">8. Advanced Standing</h3>
                <p style="text-align:justify; margin-bottom:15px;">${document.getElementById('b-adv').value.replace(/\n/g, '<br>')}</p>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">9. Programme Description</h3>
                <p style="text-align:justify; margin-bottom:15px;">${document.getElementById('b-desc').value.replace(/\n/g, '<br>')}</p>
                <h3 style="border-bottom:1px solid black; margin-top:20px; padding-bottom:5px;">10. E-learning Readiness</h3>
                <p style="direction:ltr; font-family:'Segoe UI', sans-serif; text-align:left; margin-bottom:15px;">${document.getElementById('b-elearn').value.replace(/\n/g, '<br>')}</p>
                
                <h3 style="border-bottom:1px solid black; margin-top:30px; padding-bottom:5px;">11. Program Structure Summary</h3>`;
            
            document.querySelectorAll('.dynamic-block').forEach((block) => {
                if(block.id.startsWith('sem-block')){
                    let sTitle = block.querySelector('h3').innerText.replace('Remove', '').trim();
                    html += `
                    <h4 style="margin-top:20px; color:black; font-family:'Segoe UI', sans-serif; direction:ltr;">${sTitle}</h4>
                    <table style="width:100%; border-collapse:collapse; border:1px solid black; margin-bottom:15px; direction:ltr; font-family:'Segoe UI', sans-serif; font-size:10pt; text-align:center;">
                        <tr style="background:#e6e6e6; font-weight:bold;">
                            <th style="border:1px solid black; padding:6px;">Module Title</th><th style="border:1px solid black; padding:6px;">Code</th><th style="border:1px solid black; padding:6px;">Cont. Hrs</th><th style="border:1px solid black; padding:6px;">Tot. Hrs</th><th style="border:1px solid black; padding:6px;">Credits</th>
                        </tr>`;
                    let rows = block.querySelectorAll('tbody tr');
                    rows.forEach(r => {
                        let i = r.querySelectorAll('input');
                        html += `<tr><td style="border:1px solid black; padding:4px; direction:rtl; font-family:'Faruma', serif; text-align:right;">${i[0].value}</td><td style="border:1px solid black; padding:4px;">${i[1].value}</td><td style="border:1px solid black; padding:4px;">${i[2].value}</td><td style="border:1px solid black; padding:4px;">${i[3].value}</td><td style="border:1px solid black; padding:4px;">${i[4].value}</td></tr>`;
                    });
                    html += `</table>`;
                }
            });

            html += `<h3 style="direction:ltr; font-family:'Segoe UI', sans-serif; text-align:right; margin-top:20px;">GRAND TOTAL -> Credits: <span style="color:red;">${document.getElementById('grand-cr').innerText}</span> | Total Hrs: <span style="color:red;">${document.getElementById('grand-th').innerText}</span></h3>`;

            // PART C
            html += `<div style="page-break-before: always;"></div>`;
            html += `<h1 style="direction:ltr; font-family:'Segoe UI', sans-serif; text-align:center; margin-bottom:20px; border-bottom:3px solid black; padding-bottom:10px;">PART C: Module Outlines</h1>`;
            html += modHTML; 
            
            // PART D: Annex
            html += `<div style="page-break-before: always;"></div>
                <h1 style="direction:ltr; font-family:'Segoe UI', sans-serif; text-align:center; margin-bottom:20px; border-bottom:3px solid black; padding-bottom:10px;">PART D: Annexes</h1>`;
            
            document.querySelectorAll('.dynamic-block').forEach(block => {
                if(block.querySelector('.annex-title')){
                    let aTitle = block.querySelector('.annex-title').value;
                    let aContent = block.querySelector('.annex-content').value;
                    html += `
                        <h3 style="color:black; margin-top:20px; border-bottom:1px solid #ccc; padding-bottom:5px;">${aTitle}</h3>
                        <div style="direction:rtl; text-align:justify; margin-bottom: 30px; font-family:'Faruma', 'Amiri', serif; line-height:1.8;">${aContent.replace(/\n/g, '<br>')}</div>
                    `;
                }
            });

            html += `</div>`;
            return html;
        }

        // --- EXPORT TRIGGERS (Using safe PDF rendering techniques) ---
        function exportDoc(type, format) {
            const htmlContent = type === 'module' ? buildModuleHTML() : buildFullProgramHTML();
            const fileName = type === 'module' ? `${document.getElementById('m-code').value}_Module_Outline` : `MQA_Full_Program_Document`;

            if(format === 'word') {
                const src = `<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset='utf-8'><title>${fileName}</title></head><body>${htmlContent}</body></html>`;
                const blob = new Blob(['\ufeff', src], { type: 'application/msword' });
                const link = document.createElement("a"); link.href = URL.createObjectURL(blob); link.download = `${fileName}.doc`; link.click();
            } else if (format === 'pdf') {
                const el = document.getElementById('export-render-box'); 
                el.innerHTML = htmlContent;
                el.style.display = 'block'; 
                
                html2pdf().set({ 
                    margin: 10, 
                    filename: `${fileName}.pdf`, 
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2, useCORS: true, letterRendering: true, windowWidth: 1200 }, 
                    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' } 
                }).from(el).save().then(() => el.style.display = 'none');
            }
        }
    </script>
