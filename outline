        function handleLogin() {
            document.getElementById('login-screen').style.display = 'none';
            document.getElementById('app-container').style.display = 'flex';
            calcModHours(); calcT(); calcP();
        }

        function switchStep(num, el) {
            document.querySelectorAll('.form-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-links li').forEach(l => l.classList.remove('active'));
            document.getElementById(`step-${num}`).classList.add('active');
            el.classList.add('active');
            document.getElementById('top-title').innerText = el.innerText;
        }

        // --- 2. DYNAMIC BUILDERS & CALCULATORS ---

        function addSemesterBlock() {
            semCount++;
            const container = document.getElementById('semesters-container');
            const div = document.createElement('div');
            div.className = 'dynamic-block';
            div.id = `sem-block-${semCount}`;
            div.innerHTML = `
                <h3>Semester ${semCount} <button class="remove-block-btn" onclick="this.parentElement.parentElement.remove(); calcP();">Remove</button></h3>
                <div class="table-responsive">
                    <table class="builder-table">
                        <thead><tr><th width="35%">Module Title</th><th width="15%">Code</th><th width="15%">Contact Hrs</th><th width="15%">Total Hrs</th><th width="10%">Credits</th><th width="10%">Del</th></tr></thead>
                        <tbody id="tbody-sem-${semCount}">
                            <tr>
                                <td><input type="text" class="rtl-input" value="دروس اللغة العربية (1)"></td>
                                <td><input type="text" class="ltr-input" value="ARA5001"></td>
                                <td><input type="number" class="ltr-input p-ch" value="0" readonly></td>
                                <td><input type="number" class="ltr-input p-th" value="0" readonly></td>
                                <td><input type="number" class="ltr-input p-cr" value="23" oninput="calcP(this)"></td>
