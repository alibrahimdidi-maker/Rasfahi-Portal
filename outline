                            </tr>
                        </tbody>
                        <tfoot><tr class="tfoot-total"><td colspan="2" style="text-align:right;">SEM TOTALS:</td><td class="st-ch">0</td><td class="st-th" style="color:red;">0</td><td class="st-cr" style="color:red;">0</td><td></td></tr></tfoot>
                    </table>
                </div>
                <button class="btn btn-green" onclick="addModuleToSem('${semCount}')">+ Add Module to Sem ${semCount}</button>
            `;
            container.appendChild(div);
            calcP();
        }

        function addModuleToSem(id) {
            const tb = document.getElementById(`tbody-sem-${id}`);
            const tr = document.createElement('tr');
            tr.innerHTML = `<td><input type="text" class="rtl-input"></td><td><input type="text" class="ltr-input"></td><td><input type="number" class="ltr-input p-ch" value="0" readonly></td><td><input type="number" class="ltr-input p-th" value="0" readonly></td><td><input type="number" class="ltr-input p-cr" value="0" oninput="calcP(this)"></td><td><button class="btn-danger" onclick="deleteRow(this); calcP();">X</button></td>`;
            tb.appendChild(tr);
        }

        function addAnnexBlock() {
            annexCount++;
            const container = document.getElementById('annex-container');
            const div = document.createElement('div');
            div.className = 'dynamic-block';
            div.innerHTML = `
                <h3>Annex Document <button class="remove-block-btn" onclick="this.parentElement.parentElement.remove();">Remove</button></h3>
                <div class="form-group"><input type="text" class="ltr-input annex-title" placeholder="Annex Title (e.g. Student Rules)" value="ޒާދް އެކަޑެމީގެ ޕްރޮގްރާމްތަކުގެ ދަރިވަރުންގެ ޤަވާޢިދު"></div>
                <div class="form-group"><textarea class="rtl-input tall-textarea annex-content">ޒާދް އެކަޑެމީގެ ކޮންމެ ދަރިވަރަކީ މާތްވެގެންވާ އިސްލާމް ދީނަށް ލޯބިކުރާ ކީރިތި ޤުރްއާނާއި ރަސޫލާގެ ސުންނަތާ އެއްގޮތަށް ޢަމަލުކުރާ ދަރިވަރަކަށް ވާންވާނެއެވެ.</textarea></div>
            `;
            container.appendChild(div);
        }

        function deleteRow(btn) { btn.closest('tr').remove(); }

        // Core Calculation Engine
        function recalculateAllRows() {
            // Re-trigger calculation for all credit inputs in the document
            document.querySelectorAll('.p-cr').forEach(inp => calcP(inp));
            calcModHours();
            calcT();
        }

        function calcP(inputElem) {
            let lvl = parseInt(document.getElementById('p-level').value) || 5;

            // If triggered by a specific row's credit input
            if (inputElem && inputElem.classList.contains('p-cr')) {
                let row = inputElem.closest('tr');
                let cr = Number(inputElem.value) || 0;
                let tot = cr * 10;
                let con = (lvl <= 3) ? (tot * 0.5) : (tot / 3);
                row.querySelector('.p-th').value = tot;
                row.querySelector('.p-ch').value = Math.round(con);
            }

            // Global Totals
            let gCh=0, gTh=0, gCr=0;
            document.querySelectorAll('.dynamic-block').forEach(block => {
                let sCh=0, sTh=0, sCr=0;
                block.querySelectorAll('.p-ch').forEach(i => { sCh += Number(i.value)||0; });
                block.querySelectorAll('.p-th').forEach(i => { sTh += Number(i.value)||0; });
                block.querySelectorAll('.p-cr').forEach(i => { sCr += Number(i.value)||0; });
                
                if(block.querySelector('.st-ch')) block.querySelector('.st-ch').innerText = sCh;
                if(block.querySelector('.st-th')) block.querySelector('.st-th').innerText = sTh;
                if(block.querySelector('.st-cr')) block.querySelector('.st-cr').innerText = sCr;

                gCh += sCh; gTh += sTh; gCr += sCr;
            });

            document.getElementById('grand-ch').innerText = gCh;
            document.getElementById('grand-th').innerText = gTh;
            document.getElementById('grand-cr').innerText = gCr;
        }

        function calcModHours() {
            let cr = Number(document.getElementById('m-credits').value) || 0;
            let lvl = parseInt(document.getElementById('p-level').value) || 5;
            let tot = cr * 10;
            let con = (lvl <= 3) ? (tot * 0.5) : (tot / 3);
            
            document.getElementById('m-tot-hrs').value = tot;
            document.getElementById('m-contact-hrs').value = Math.round(con);
